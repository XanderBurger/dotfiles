// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.

{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "base_keymap": "Emacs",
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "model_parameters": [],
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-latest"
    }
  },
  "disable_ai": true,
  "show_edit_predictions": true,
  "show_completions_on_input": true,
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": false
  },
  "current_line_highlight": "none",
  "cursor_blink": false,
  "theme": "Minoblong",
  "vim_mode": false,
  "relative_line_numbers": "disabled",
  "ui_font_size": 15,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrains Mono",
  "ui_font_family": "Inclusive Sans",
  // "show_diagnostics": "errors",
  "format_on_save": "on",
  // "diagnostics": {
  //   "include_warnings": true,
  //   "inline": {
  //     "enabled": true,
  //     "min_severity": "warnning"
  //   },
  //   "update_with_cursor": false,
  //   "primary_only": false,
  //   "use_rendered": false
  // },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },
  // "diagnostics_max_severity": "error",
  "scrollbar": {
    "diagnostics": "error",
    "git_diff": false
  },
  "project_panel": {
    "button": true,
    "default_width": 240,
    "dock": "left",
    "entry_spacing": "comfortable",
    "file_icons": true,
    "folder_icons": true,
    "git_status": false,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "scrollbar": {
      "show": null
    },
    "show_diagnostics": "errors",
    "indent_guides": {
      "show": "always"
    }
  },
  "experimental.theme_overrides": {
    "players": [
      {
        "cursor": "#c474bc",
        // "background": "#3a3a3a",
        "selection": "#3a3a3a"
      }
    ]
  },
  "languages": {
    "Templ": {
      "enable_language_server": true,
      "show_completions_on_input": true,
      "linked_edits": false
    }
  }
}
